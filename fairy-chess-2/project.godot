; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Fairy Chess 2"
run/main_scene="res://fairy_chess.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://Fairy Chess Logo.jpg"

[autoload]

PlayerDatabase="*res://Global/player_database.gd"

[display]

window/size/mode=2

[gui]

; Generated by tools/build_theme.gd -- edit that script, not the .tres.
; theme/custom_font is deliberately left unset: the theme assigns Cinzel to the
; display types itself, and the engine's Open Sans SemiBold stays the body face.
theme/custom="res://ui/fairy_chess_theme.tres"
