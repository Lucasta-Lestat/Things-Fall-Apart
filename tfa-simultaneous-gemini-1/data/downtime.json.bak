{
	"activities": {
		"carousing": {
			"name": "Carousing",
			"description": "Socialise, party, drink, brawl. Loosens the mind and dulls the lingering ache of past horrors.",
			"duration_hours": 4,
			"urban": true,
			"rural": false,
			"preferred_traits": ["Sociable", "Aggressive"],
			"disliked_traits": ["Chaste", "Reclusive"],
			"ability_check": "",
			"default_effects": {"remove_mental_affliction": 1},
			"legal_title": "",
			"results": {
				"any_map": {
					"partied_hard": {
						"weight": 6,
						"event_description": " had a wild night and made some new friends. A generous benefactor pressed silver into their hand at dawn.",
						"effects": {"money": 10, "remove_mental_affliction": 1}
					},
					"brawl": {
						"weight": 3,
						"event_description": " got into a tavern brawl. Black eye, split lip, broken nose. Lost some coin on side bets.",
						"effects": {"hp": -3, "money": -5},
						"required_traits": ["Aggressive"]
					},
					"catfished": {
						"weight": 3,
						"event_description": " met a charming stranger who turned out to be a thief. Some valuables vanished while they were distracted.",
						"effects": {"money": -10},
						"required_traits": ["Gullible"]
					},
					"my_wife": {
						"weight": 2,
						"event_description": " was confused for the long-lost lover of a ravishing ogre maiden whose brutish entourage now hopes you'll do the honourable thing.",
						"effects": {"favorability": -2}
					},
					"rodomontade": {
						"weight": 2,
						"event_description": " boasted loudly about their exploits all night, amplifying the reputational impact (good and bad) of recent adventures.",
						"effects": {"hp": -2, "money": -10}
					},
					"face_rats": {
						"weight": 1,
						"event_description": " was set upon by alchemically-bred face rats. The wounds healed but the disfigurement will need stronger magic to undo.",
						"effects": {"hp": -6, "add_condition": "scarred"}
					},
					"long_lost_friend": {
						"weight": 1,
						"event_description": " was approached by a haggard mercenary returning from the East — a friend long thought dead, now in chains being paraded to the docks.",
						"effects": {"favorability": 3}
					},
					"recruit_meet": {
						"weight": 1,
						"event_description": " hit it off with a wandering adventurer who hinted at being available for hire.",
						"effects": {"favorability": 2}
					},
					"quiet_night": {
						"weight": 4,
						"event_description": " drank in the corner and listened. Heard nothing important, but slept it off well.",
						"effects": {"remove_mental_affliction": 1}
					}
				}
			}
		},

		"drinking": {
